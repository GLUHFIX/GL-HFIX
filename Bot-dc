def check_running():
    if not running:
        raise asyncio.CancelledError("Routine wurde abgebrochen")

async def loesche_alle_channels(guild):
    channels = list(guild.channels)
    tasks = [ch.delete(reason="Server reset durch Bot") for ch in channels]
    await asyncio.gather(*tasks, return_exceptions=True)

async def loesche_alle_rollen(guild, bot_member):
    rollen_zu_loeschen = [r for r in guild.roles if r != guild.default_role and r != bot_member.top_role]
    for rolle in rollen_zu_loeschen:
        try:
            await rolle.delete(reason="Rollen löschen")
        except:
            pass

async def loesche_alle_emojis(guild):
    for emoji in guild.emojis:
        try:
            await emoji.delete(reason="Emojis löschen")
        except:
            pass

async def loesche_alle_sticker(guild):
    try:
        for sticker in await guild.stickers():
            try:
                await sticker.delete(reason="Sticker löschen")
            except:
                pass
